---
interface Props {
text: String
}

const {text} = Astro.props;
---


<label class="flex justify-center items-center p-2 gap-2 h-8 w-28 border-[#47B515] bg-[#32ff2b5b] rounded-sm cursor-pointer hover:bg-[#2bff4786]">
  <span class="text-[#47B515] text-base  font-semibold">{text}</span>
</label>

<style>
  @keyframes spin {
      0% {
          transform: rotate(0deg);
      }
      100% {
          transform: rotate(-360deg);
      }
  }
  .button:hover .svg-icon {
      animation: spin 2s linear infinite;
  }
</style>

