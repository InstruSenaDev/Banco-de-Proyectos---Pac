---
import Navbar from "../Components/Navbar.astro";
import Menu from "../Components/Menu.astro";
import PostLayout from "./PostLayout.astro";
import BotonDevolver from "../Components/BotonDevolver.astro";

interface Props { //TypeScript
    title: string;
}

const { title } = Astro.props;
---

<PostLayout {title}>
    <div>
    <header class="w-full bg-white  ">
        <Navbar Text="Karen"/>
    </header>

    <aside>
        <Menu/>
    </aside>
        
<div class="px-28">
    <a href="/HomeSuperAdmin">
    <BotonDevolver/>
</a>
</div>

    <slot/>
</div>

</PostLayout>