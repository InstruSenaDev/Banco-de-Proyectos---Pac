---
import Input from "../Components/Input.astro"
import BotonPrincipal from "../Components/BotonPrincipal.astro"
import SelectBoxTI from "../Components/SelectBoxTI.astro"
import SelectBoxRol from "../Components/SelectBoxRol.astro"
import RadioButton from "../Components/RadioButton.astro"
import LayoutsCrearUsuario from '../layouts/LayoutsCrearUsuario.astro';
import Layoutprincipal from "../layouts/Layoutprincipal.astro";
import Layoutcontenido from "../layouts/Layoutcontenido.astro"
import Modal from "../Components/Modal.astro"
---

<link href="https://fonts.googleapis.com/css?family=Josefin+Sans&display=swap" rel="stylesheet" />

<style>
    .font-josefin-slab {
        font-family: 'Josefin Slab', serif;
    }
</style>

<Layoutprincipal title="Crear Usuario">
    <Layoutcontenido title="Crear Usuario">
        <div class="flex-box flex flex-col space-y-8 w-1/2">
            <Input Text="Nombre del usuario:" placeholder="Ej: Pepito Perez" type="text"/>
            <div class=" w-1/2">
                <SelectBoxTI Text="Tipo de documento"/>
            </div>
            <Input Text="Número de documento:" placeholder="Ej: 123456789" type="text"/>
            <Input Text="Correo Electrónico:" placeholder="Ej: ejemplo@gmail.com" type="email"/>
        </div>

        <div class="flex-box flex flex-col space-y-8 w-1/2">
            <Input Text="Contraseña:" placeholder=".............." type="password"/>
            <div class=" w-1/2">
                 <SelectBoxRol Text="Rol del usuario:"/>
            </div>
           
            <div class=" space-y-11">
            <div class="flex-box flex flex-col space-y-6">
                <h1 class="font-josefin-slab text-black font-semibold ">Estado:</h1>
                <div class="flex space-x-8">
                    <RadioButton Text="Activo"/> <RadioButton Text="Inactivo"/>
                </div>
            </div>
            </div>
            <div class="flex-box flex flex-col space-y-5 w-1/2 ">
                    <Input Text="Celular:" placeholder="Ej: 312456789" type="text"/>
            </div>

            <div class="flex justify-end show-modal">
                <BotonPrincipal Text="Guardar"/>
            </div>
        </div>
        </div>
    </div>
</div>
</div>

   <Modal > 

<script>
    const modal = document.querySelector('.modal');

    const showModal = document.querySelector('.show-modal');
    const closeModal = document.querySelector('.close-modal')

    showModal?.addEventListener('click', function(){
        modal?.classList.remove('hidden')
    });

    closeModal?.addEventListener('click', function(){
        modal?.classList.add('hidden')
    });
</script>
    </Layoutcontenido>
</Layoutprincipal>
